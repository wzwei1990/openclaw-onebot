{
  "name": "openclaw-onebot",
  "displayName": "OpenClaw OneBot",
  "version": "1.2.10",
  "description": "OpenClaw OneBot 11 channel plugin for QQ messaging. Native integration with NapCat/go-cqhttp — voice pipeline, reactions, block streaming, and media delivery.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "openclaw.plugin.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xucheng/openclaw-onebot.git"
  },
  "homepage": "https://github.com/xucheng/openclaw-onebot#readme",
  "bugs": {
    "url": "https://github.com/xucheng/openclaw-onebot/issues"
  },
  "author": "JerryXu",
  "license": "MIT",
  "clawdbot": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "moltbot": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "compat": {
      "pluginApi": ">=2026.3.23-1",
      "minGatewayVersion": "2026.3.23-1"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.4.9"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "prepare:clawhub:plugin": "npm run build && node ./scripts/prepare-clawhub-plugin.mjs",
    "react-test": "node ./scripts/react-test.mjs",
    "release:check": "npm run build && npm test && npm run pack:dry-run && npm run prepare:clawhub:plugin",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "sync:openclaw-cli": "node ./scripts/sync-openclaw-cli.mjs"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "bundledDependencies": [
    "ws"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "openclaw": "^2026.4.9",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "moltbot": "*",
    "openclaw": ">=2026.3.23-1 <2027"
  },
  "bundleDependencies": [
    "ws"
  ]
}
