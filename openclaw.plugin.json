{
  "id": "openclaw-onebot",
  "name": "OneBot",
  "description": "OneBot 11 channel plugin (NapCat/go-cqhttp)",
  "version": "1.2.12",
  "channels": ["onebot"],
  "channelEnvVars": {
    "onebot": [
      "ONEBOT_WS_URL",
      "ONEBOT_HTTP_URL",
      "ONEBOT_ACCESS_TOKEN",
      "ONEBOT_SHARED_DIR",
      "ONEBOT_CONTAINER_SHARED_DIR"
    ]
  },
  "configSchema": {
    "type": "object",
    "properties": {},
    "additionalProperties": false
  },
  "channelConfigs": {
    "onebot": {
      "label": "OneBot",
      "description": "OneBot 11 channel settings for NapCat/go-cqhttp",
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "name": {
            "type": "string",
            "description": "Display name for this account"
          },
          "wsUrl": {
            "type": "string",
            "description": "OneBot WebSocket URL"
          },
          "httpUrl": {
            "type": "string",
            "description": "OneBot HTTP API URL"
          },
          "accessToken": {
            "type": "string",
            "description": "Access token for OneBot API"
          },
          "sharedDir": {
            "type": "string",
            "description": "Host directory mounted into NapCat for outbound media/files"
          },
          "containerSharedDir": {
            "type": "string",
            "description": "Container path corresponding to the shared host directory"
          },
          "allowFrom": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Allowed sources (e.g. private:123, group:456)"
          },
          "groupAutoReact": {
            "type": "boolean",
            "default": true,
            "description": "Automatically add a reaction to inbound group messages"
          },
          "groupAutoReactEmojiId": {
            "description": "QQ/NapCat emoji id used for automatic group reactions",
            "default": 1,
            "oneOf": [
              { "type": "integer" },
              { "type": "string" }
            ]
          },
          "requireMention": {
            "type": "boolean",
            "default": false,
            "description": "Require an @mention in group messages before the bot replies"
          },
          "triggerKeywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Keywords that trigger a reply when present in a message"
          },
          "configWrites": {
            "type": "boolean",
            "description": "Allow channel-initiated config writes"
          },
          "commands": {
            "$ref": "#/$defs/commands"
          },
          "textChunkLimit": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "chunkMode": {
            "type": "string",
            "enum": ["length", "newline"]
          },
          "blockStreaming": {
            "type": "boolean"
          },
          "blockStreamingCoalesce": {
            "$ref": "#/$defs/blockStreamingCoalesce",
            "description": "Block streaming coalescing options for OneBot replies"
          },
          "streaming": {
            "$ref": "#/$defs/streaming"
          },
          "accounts": {
            "type": "object",
            "description": "Additional OneBot accounts",
            "additionalProperties": {
              "$ref": "#/$defs/account"
            }
          }
        },
        "additionalProperties": false,
        "$defs": {
          "blockStreamingCoalesce": {
            "type": "object",
            "properties": {
              "minChars": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "maxChars": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "idleMs": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "commands": {
            "type": "object",
            "properties": {
              "native": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "const": "auto" }
                ]
              },
              "nativeSkills": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "const": "auto" }
                ]
              }
            },
            "additionalProperties": false
          },
          "streaming": {
            "type": "object",
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["off", "partial", "block", "progress"]
              },
              "chunkMode": {
                "type": "string",
                "enum": ["length", "newline"]
              },
              "block": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "coalesce": {
                    "$ref": "#/$defs/blockStreamingCoalesce"
                  }
                },
                "additionalProperties": false
              },
              "preview": {
                "type": "object",
                "properties": {
                  "toolProgress": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              },
              "nativeTransport": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "account": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "name": { "type": "string" },
              "wsUrl": { "type": "string" },
              "httpUrl": { "type": "string" },
              "accessToken": { "type": "string" },
              "sharedDir": { "type": "string" },
              "containerSharedDir": { "type": "string" },
              "allowFrom": {
                "type": "array",
                "items": { "type": "string" }
              },
              "groupAutoReact": {
                "type": "boolean",
                "default": true
              },
              "groupAutoReactEmojiId": {
                "default": 1,
                "oneOf": [
                  { "type": "integer" },
                  { "type": "string" }
                ]
              },
              "requireMention": {
                "type": "boolean",
                "default": false
              },
              "triggerKeywords": {
                "type": "array",
                "items": { "type": "string" }
              },
              "configWrites": { "type": "boolean" },
              "commands": { "$ref": "#/$defs/commands" },
              "textChunkLimit": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "chunkMode": {
                "type": "string",
                "enum": ["length", "newline"]
              },
              "blockStreaming": { "type": "boolean" },
              "blockStreamingCoalesce": { "$ref": "#/$defs/blockStreamingCoalesce" },
              "streaming": { "$ref": "#/$defs/streaming" }
            },
            "additionalProperties": false
          }
        }
      },
      "uiHints": {
        "wsUrl": {
          "label": "WebSocket URL",
          "placeholder": "ws://localhost:3001"
        },
        "httpUrl": {
          "label": "HTTP API URL",
          "placeholder": "http://localhost:3001"
        },
        "accessToken": {
          "label": "Access token",
          "sensitive": true
        },
        "sharedDir": {
          "label": "Shared directory"
        },
        "containerSharedDir": {
          "label": "Container shared directory",
          "placeholder": "/shared"
        }
      }
    }
  }
}
